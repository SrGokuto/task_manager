{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/js/(.*)",
            "dest": "public/js/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "public/css/$1"
        },
        {
            "src": "/(.*)\\.html",
            "dest": "public/$1.html"
        },
        {
            "src": "/login",
            "dest": "public/login.html"
        },
        {
            "src": "/register",
            "dest": "public/register.html"
        },
        {
            "src": "/(.*)",
            "dest": "public/$1"
        }
    ]
}